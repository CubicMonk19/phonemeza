# Copy this file to deploy/.env and fill in real values.
# deploy/.env is gitignored — never commit real IPs, domains, or key paths.

# Public domain served by Caddy (must have an A record pointing at EC2_HOST).
DOMAIN=phonemeza.example.com

# Public IPv4 of the EC2 host. Used both as the SSH target and for the
# pre-flight DNS check (DOMAIN's A record must equal this).
EC2_HOST=203.0.113.10

# SSH login user on the host (Ubuntu AMIs use "ubuntu"). Must be able to run
# docker without sudo (i.e. be a member of the "docker" group).
SSH_USER=ubuntu

# Path to the private key for SSH/SCP. Windows paths are fine; quote if it
# contains spaces.
SSH_KEY=C:\Users\you\.ssh\phonemeza.pem

# Optional: directory on the host to deploy into. Defaults to
# /home/<SSH_USER>/phonemeza when unset.
REMOTE_DIR=/home/ubuntu/phonemeza
